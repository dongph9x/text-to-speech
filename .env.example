DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: limit to one guild for faster command propagation during development
GUILD_ID=

# Google Cloud credentials (chọn MỘT trong các cách dưới đây):
# Cách 1 (đơn giản nhất): API key tạo trên GCP (APIs & Services > Credentials)
GOOGLE_TTS_API_KEY=

# Cách 2: đường dẫn tuyệt đối đến file service account JSON
GOOGLE_APPLICATION_CREDENTIALS=

# Cách 3: inline JSON service account (dán toàn bộ JSON trên một dòng)
GOOGLE_TTS_KEY_JSON=

REGISTER_COMMANDS_ON_STARTUP=false
DEFAULT_TTS_RATE=
SILENT_MODE=ack
CLEAR_DELAY_MS=5000

# -------- Gemini-TTS (mặc định cho tất cả) --------
# Model dùng để tổng hợp. Mặc định: gemini-2.5-flash-tts
GEMINI_TTS_MODEL=gemini-2.5-flash-tts
# Giọng mặc định (tên Gemini-TTS, vd: Leda, Umbriel, Sulafat). Mặc định: Leda
DEFAULT_TTS_VOICE=Leda
# Phong cách đọc mặc định (prompt điều khiển). Để trống sẽ dùng câu mặc định.
DEFAULT_TTS_STYLE=Read aloud in a warm, welcoming tone.
# (Tùy chọn) Style riêng cho lời chào / tạm biệt; bỏ trống sẽ dùng DEFAULT_TTS_STYLE
GREETING_STYLE=
FAREWELL_STYLE=